{
  "name": "guestly-backend",
  "version": "1.0.0",
  "description": "Guestly restaurant reservation backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon src/server.js",
    "client": "cd frontend && npm run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:coverage": "jest --verbose --coverage"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2"
  }
}
